@startuml reporting-and-evidence-overview
!theme plain
skinparam backgroundColor #FFFFFF
left to right direction
title Диаграмма вариантов использования: Отчетность и доказательная база (Reporting and Evidence)

actor "BC Оркестрация проверок качества (Quality Gate Orchestration BC)" as QGO
actor "BC Пакеты проверок (Verification Packages BC)" as VP
actor "Разработчик (Developer)" as Dev

rectangle "Отчетность и доказательная база (Reporting and Evidence)" {
  usecase "Публиковать PR summary и доказательную базу\n(Publish PR Summary and Evidence)" as UC1
  usecase "Принять итог gate-запуска\n(Receive Gate Run Result)" as UC2
  usecase "Принять детали верификации\n(Receive Verification Details)" as UC3
  usecase "Сформировать и опубликовать сводку PR\n(Build and Publish PR Summary)" as UC4
  usecase "Запросить повторную выгрузку логов\n(Request Log Reupload)" as UC5
}

Dev --> UC1
QGO --> UC2
VP --> UC3

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC5 ..> UC1 : <<extend>>

@enduml
