@startuml reporting-and-evidence-overview
!theme plain
skinparam backgroundColor #FFFFFF
title Диаграмма вариантов использования: Отчетность и доказательная база (Reporting and Evidence)

actor "Система непрерывной интеграции (Continuous Integration System)" as CI
actor "Разработчик (Developer)" as Dev
actor "Технический лидер и архитектор (Tech Lead and Architect)" as Lead

rectangle "Отчетность и доказательная база (Reporting and Evidence)" {
  usecase "Сформировать сводку запуска (Build Run Summary)" as UC1
  usecase "Связать доказательные артефакты (Link Evidence Artifacts)" as UC2
  usecase "Опубликовать сводку PR (Publish PR Summary)" as UC3
  usecase "Обновить верификационный отчет (Update Verification Report)" as UC4
  usecase "Запросить повторную выгрузку логов (Request Log Reupload)" as UC5
}

CI --> UC1
CI --> UC2
CI --> UC3
Lead --> UC4
Dev --> UC3
Dev --> UC5

UC3 ..> UC2 : <<include>>

@enduml

