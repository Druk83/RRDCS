@startuml verification-packages-overview
!theme plain
skinparam backgroundColor #FFFFFF
title Диаграмма вариантов использования: Пакеты проверок (Verification Packages)

actor "Система непрерывной интеграции (Continuous Integration System)" as CI
actor "Разработчик (Developer)" as Dev

rectangle "Пакеты проверок (Verification Packages)" {
  usecase "Запустить набор проверок (Start Verification Set)" as UC1
  usecase "Запустить стилевые проверки (Run Style Checks)" as UC2
  usecase "Запустить проверки безопасности (Run Security Checks)" as UC3
  usecase "Запустить матрицу платформ (Run Platform Matrix Checks)" as UC4
  usecase "Опубликовать результаты проверок (Publish Verification Results)" as UC5
}

CI --> UC1
CI --> UC2
CI --> UC3
CI --> UC4
CI --> UC5
Dev --> UC5

UC5 ..> UC2 : <<include>>
UC5 ..> UC3 : <<include>>
UC5 ..> UC4 : <<include>>

@enduml

