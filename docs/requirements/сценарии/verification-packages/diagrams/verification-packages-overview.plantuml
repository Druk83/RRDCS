@startuml verification-packages-overview
!theme plain
skinparam backgroundColor #FFFFFF
left to right direction
title Диаграмма вариантов использования: Пакеты проверок (Verification Packages)

actor "BC Оркестрация проверок качества (Quality Gate Orchestration BC)" as QGO
actor "BC Отчетность и доказательная база (Reporting and Evidence BC)" as RE

rectangle "Пакеты проверок (Verification Packages)" {
  usecase "Выполнить базовый набор проверок\n(Execute Baseline Verification Set)" as UC1
  usecase "Запустить стилевые проверки\n(Run Style Checks)" as UC2
  usecase "Запустить проверки безопасности\n(Run Security Checks)" as UC3
  usecase "Запустить матрицу платформ\n(Run Platform Matrix Checks)" as UC4
  usecase "Опубликовать результаты проверок\n(Publish Verification Results)" as UC5
}

QGO --> UC1
RE --> UC5

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC1 ..> UC5 : <<include>>

@enduml
