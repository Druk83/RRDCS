@startuml ContextMap_policy-and-toolchain-governance
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
title Карта контекстов (Context Map): Управление политиками и цепочкой инструментов (Policy and Toolchain Governance)

skinparam component {
    BackgroundColor<<Core>> #FFF59D
    BackgroundColor<<Supporting>> #B3E5FC
    BackgroundColor<<External>> #F8BBD9
    BackgroundColor<<ACL>> #FFCC80
}

component "BC: Управление политиками и цепочкой инструментов\n(Policy and Toolchain Governance)" as GOV <<Core>>
component "BC: Оркестрация проверок качества\n(Quality Gate Orchestration)" as QGO <<Supporting>>
component "BC: Пакеты проверок\n(Verification Packages)" as VP <<Supporting>>
component "Внешняя система: Git-репозиторий / Поток PR\n(Git Repository / PR Flow)" as PR <<External>>
component "ACL: Адаптер governance-событий PR\n(PR Governance Adapter)" as ACL1 <<ACL>>

PR -[#FF9800]-> ACL1
ACL1 -[#FF9800]-> GOV : ACL
GOV -[#1976D2,thickness=2]-> QGO : Поставщик/Потребитель (U/D)
GOV -[#1976D2,thickness=2]-> VP : Поставщик/Потребитель (U/D)
GOV .[#2196F3,dashed].> QGO : Событие: политика опубликована в оркестрацию\n(PolicyPublishedToOrchestrator)
GOV .[#2196F3,dashed].> VP : Событие: решение governance зафиксировано\n(GovernanceDecisionRecorded)

legend right
|= Тип |= Цвет |
| Основной контекст (Core) | Желтый |
| Поддерживающий контекст (Supporting) | Голубой |
| Внешняя система (External) | Розовый |
| Слой ACL (ACL) | Оранжевый |
endlegend

@enduml
